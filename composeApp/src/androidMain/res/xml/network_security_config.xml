<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Network Security Configuration
  https://developer.android.com/training/articles/security-config

  Policy:
    - Production domain  → HTTPS only + certificate pinning
    - Local dev IPs      → cleartext permitted (emulator / simulator only)
    - Everything else    → system default (cleartext blocked on API 28+)

  ════════════════════════════════════════════════════════════════
  HOW TO GET YOUR PIN HASHES
  ════════════════════════════════════════════════════════════════
  Run against your live server:

    openssl s_client -connect api.yourapp.com:443 </dev/null 2>/dev/null | \
      openssl x509 -pubkey -noout | \
      openssl pkey -pubin -outform DER | \
      openssl dgst -sha256 -binary | base64

  Pin at least TWO hashes: current cert + backup (CA intermediate or next cert).
  These same hashes must be set in PlatformHttpEngine.kt (OkHttp CertificatePinner).
  ════════════════════════════════════════════════════════════════
-->
<network-security-config>

    <!-- ── Production domain ──────────────────────────────────────────────── -->
    <!-- Replace "api.yourapp.com" with your actual API hostname. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">api.yourapp.com</domain>

        <!-- Rejects any TLS cert whose public-key hash is not in this list,
             even if it chains to a trusted root CA. -->
        <pin-set expiration="2027-01-01">
            <!-- TODO: replace with real SHA-256 of your server cert public key -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <!-- TODO: replace with real SHA-256 of your CA intermediate public key -->
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>

        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>

    <!-- ── Local development only ─────────────────────────────────────────── -->
    <!-- Cleartext permitted ONLY for loopback addresses. Never reachable in prod. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
