# Copy this file to .env and fill in real values.
# The Ktor server reads these at startup via System.getenv().
# Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: individual vars (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financelifeline
DB_USER=postgres
DB_PASSWORD=postgres

# Option B: single DATABASE_URL (overrides A if set)
# DATABASE_URL=jdbc:postgresql://localhost:5432/financelifeline

# ── Auth ──────────────────────────────────────────────────────────────────────
# Minimum 32 random characters in production.
# Generate one: openssl rand -base64 32
JWT_SECRET=dev-secret-change-in-production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Leave empty for dev (any host allowed).
# In production: ALLOWED_ORIGINS=https://app.yourapp.com
ALLOWED_ORIGINS=
