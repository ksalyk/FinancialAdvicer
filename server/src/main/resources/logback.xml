<configuration>

    <!-- ── Console appender ──────────────────────────────────────────────── -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Format: timestamp [thread] LEVEL logger - message -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %-40logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Rolling file appender ─────────────────────────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Daily rotation, keep 14 days -->
            <fileNamePattern>logs/server.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %-40logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Logger configuration ──────────────────────────────────────────── -->

    <!-- App-specific loggers: DEBUG in all environments for full call tracing -->
    <logger name="AuthRoutes"  level="DEBUG"/>
    <logger name="GameRoutes"  level="DEBUG"/>

    <!-- Ktor internals: INFO to avoid overwhelming output -->
    <logger name="io.ktor"                   level="INFO"/>
    <logger name="io.ktor.server.routing"    level="WARN"/>  <!-- suppress route tree dump -->

    <!-- Exposed SQL: set TRACE locally to see raw queries, INFO in prod -->
    <logger name="Exposed" level="INFO"/>

    <!-- HikariCP: only show connection pool warnings -->
    <logger name="com.zaxxer.hikari" level="WARN"/>

    <!-- Root: INFO for everything else -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
